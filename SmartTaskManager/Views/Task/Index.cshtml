@using SmartTaskManager.Core.Entities
@model IEnumerable<TaskItem>
@{
    ViewData["Title"] = "Tasks";
}

<h2 class="mt-3 mb-4">Tasks</h2>

<div class="d-flex justify-content-between mb-3">
    <input type="text" id="searchBox" class="form-control me-2" placeholder="Search..."
           value="@ViewData["CurrentSearch"]" style="max-width:250px;" />
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> New Task
    </a>
</div>

<div id="tasksTable" style="min-height: calc(100vh - 300px);">
    @await Html.PartialAsync("_TasksTablePartial", Model)
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let currentSortColumn = '@ViewData["CurrentSortColumn"]';
        let currentSortDir = '@ViewData["CurrentSortDir"]';
        let currentSearch = '@ViewData["CurrentSearch"]';
        let currentPage = @ViewData["Page"];

        function loadTable(page = 1) {
            const container = $('#tasksTable');
            const height = container.height();
            container.html('<div style="height:' + height + 'px; display:flex; align-items:center; justify-content:center;">Loading...</div>');

            $.get('@Url.Action("Index")', {
                sortColumn: currentSortColumn,
                sortDir: currentSortDir,
                search: $('#searchBox').val(),
                page: page
            }, function (data) {
                container.html(data);
            });
        }

        function updateContainerHeight() {
            $('#tasksTable').css('min-height', $(window).height() - 300);
        }
        $(window).on('resize', updateContainerHeight);
        $(document).ready(updateContainerHeight);

        $(document).on('click', '.sort-link', function(e) {
            e.preventDefault();
            const column = $(this).data('column');
            if(currentSortColumn === column){
                currentSortDir = currentSortDir === 'asc' ? 'desc' : 'asc';
            } else {
                currentSortColumn = column;
                currentSortDir = 'asc';
            }
            loadTable();
        });

        $('#searchBox').on('keyup', function() {
            loadTable();
        });

        $(document).on('click', '.page-link', function(e) {
            e.preventDefault();
            const page = $(this).data('page');
            currentPage = page;
            loadTable(page);
        });

        $(document).on('click', '.delete-btn', function() {
            const id = $(this).data('id');
            Swal.fire({
                title: 'Are you sure?',
                text: "This task will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if(result.isConfirmed){
                    $.post('/Task/Delete/' + id, {'__RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()}, function(){
                        Swal.fire({
                            icon: 'success',
                            title: 'Deleted!',
                            showConfirmButton: false,
                            timer: 1500
                        });
                        loadTable(currentPage);
                    });
                }
            });
        });
    </script>
}
