@model IEnumerable<SmartTaskManagerCore.Core.Entities.TaskItem>

@{
    ViewData["Title"] = "Tasks";
}

<h2 class="mt-3 mb-3">Tasks List</h2>

<a asp-action="Create" class="btn btn-primary mb-3">+ New Task</a>

<table class="table table-bordered table-striped text-center align-middle">
    <thead>
        <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Priority</th>
            <th>Deadline</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var task in Model)
        {
            var deadlineClass = task.Deadline < DateTime.Now ? "text-danger fw-bold" : "";
            <tr>
                <td>@task.Title</td>

                <td>
                    @switch (task.Status)
                    {
                        case SmartTaskManagerCore.Helpers.Enums.StatusEnum.Done:
                            <span class="badge bg-success">Done</span>
                            ;
                            break;
                        case SmartTaskManagerCore.Helpers.Enums.StatusEnum.InProgress:
                            <span class="badge bg-warning text-dark">In Progress</span>
                            ;
                            break;
                        default:
                            <span class="badge bg-secondary">To Do</span>
                            ;
                            break;
                    }
                </td>

                <td>
                    @switch (task.Priority)
                    {
                        case "High":
                            <span class="badge bg-danger">High</span>
                            ;
                            break;
                        case "Medium":
                            <span class="badge bg-primary">Medium</span>
                            ;
                            break;
                        default:
                            <span class="badge bg-success">Low</span>
                            ;
                            break;
                    }
                </td>

                <td class="@deadlineClass">@task.Deadline.ToString("dd MMM yyyy")</td>
                <td>@task.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-warning me-1">Edit</a>

                    <form asp-action="Delete" asp-route-id="@task.Id" method="post" class="d-inline delete-form">
                        @Html.AntiForgeryToken()
                        <button type="button" class="btn btn-sm btn-danger delete-btn">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll('.delete-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    const form = this.closest('.delete-form');
                    Swal.fire({
                        title: 'Are you sure?',
                        text: "This task will be permanently deleted.",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        confirmButtonText: 'Yes, delete it!',
                        cancelButtonText: 'Cancel'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            form.submit(); // هيبعت الفورم للـ action
                        }
                    });
                });
            });

            @if (TempData["SuccessMessage"] != null)
            {
                    <text>
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: '@TempData["SuccessMessage"]',
                        showConfirmButton: false,
                        timer: 2500,
                        timerProgressBar: true
                    });
                    </text>
            }
        });
    </script>
}
