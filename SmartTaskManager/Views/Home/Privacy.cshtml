@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <h1 class="mb-4 animate-fade">Privacy Policy</h1>
    <p class="text-muted animate-fade delay-1">
        Your privacy is important to us. At Smart Task Manager, we are committed to protecting the personal information you share with us.
    </p>

    <section class="mt-4 animate-fade delay-2">
        <h3>1. Information We Collect</h3>
        <p class="text-muted">
            We collect only the information necessary to provide you with the best task management experience. This includes your username, email, and tasks data.
        </p>
    </section>

    <section class="mt-4 animate-fade delay-3">
        <h3>2. How We Use Your Information</h3>
        <p class="text-muted">
            Your information is used solely to manage your tasks, personalize your experience, and improve our services. We never sell or share your personal information with third parties.
        </p>
    </section>

    <section class="mt-4 animate-fade delay-1">
        <h3>3. Security</h3>
        <p class="text-muted">
            We implement appropriate technical and organizational measures to protect your data against unauthorized access, alteration, or disclosure.
        </p>
    </section>

    <section class="mt-4 animate-fade delay-2">
        <h3>4. Your Rights</h3>
        <p class="text-muted">
            You have the right to access, correct, or delete your personal data. You can contact us anytime for any privacy concerns.
        </p>
    </section>

    <section class="mt-4 animate-fade delay-3">
        <h3>5. Contact Us</h3>
        <p class="text-muted">
            For any questions about this privacy policy, please contact us at <a href="mailto:support@smarttaskmanager.com">support@smarttaskmanager.com</a>.
        </p>
    </section>
</div>
